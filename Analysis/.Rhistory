n
n <- 100
num_simulations <- 10
power_vec <- numeric(num_simulations)
sig_vec <- numeric(num_simulations)
for(i in 1:num_simulations) {
sim_data <- tibble(
participant    = numeric(n*5),
stim_index      = numeric(n*5),
TCJ            = numeric(n*5),
condition      = character(n*5),
preemption     = logical(n*5),
baseline_RT    = numeric(n*5)
)
sim_data$condition <- c(rep(0, (n/2)*5), rep(1, (n/2)*5))
preempt <- c(rep(FALSE, n*1.25), rep(TRUE, n*1.25))
sim_data$preemption <- c(preempt, preempt)
part_ind <- 1
for (j in seq(from = 1, to = n*5, by = 5)) {
if (sim_data$preemption[j] == T) {
sim_data$stim_index[j: (j+4)] = c(1:5)
}
else {
sim_data$stim_index[j: (j+4)] = c(6:10)
}
sim_data$participant[j: (j+4)] = rep(part_ind, 5)
part_ind <- part_ind + 1
}
b_i <- rnorm(n, 0, params$sd_part)
sim_data$b_i <- rep(b_i, each = 5)
k_items <- 5
Sigma_item <- matrix(c(params$sd_item_intercept^2,
params$cor_item * params$sd_item_intercept * params$sd_item_NC_slope,
params$cor_item * params$sd_item_intercept * params$sd_item_NC_slope,
params$sd_item_NC_slope^2), nrow = 2)
item_re1 <- MASS::mvrnorm(n = k_items, mu = c(0,0), Sigma = Sigma_item)
# For the next 5 items
item_re2 <- MASS::mvrnorm(n = k_items, mu = c(0,0), Sigma = Sigma_item)
sim_data$u_j <- NA
sim_data$v_j <- NA
for (s in 1:10) {
if (s <= 5) {
sim_data$u_j[sim_data$stim_index == s] <- item_re1[s,1]
sim_data$v_j[sim_data$stim_index == s] <- item_re1[s,2]
} else {
sim_data$u_j[sim_data$stim_index == s] <- item_re2[s-5,1]
sim_data$v_j[sim_data$stim_index == s] <- item_re2[s-5,2]
}
}
sim_data$baseline_RT <- rnorm(n*5, params$mu_brt, params$sd_brt)
sim_data$TCJ <- params$beta0 +
params$delta_hat * sim_data$condition +
params$beta_PRE * as.numeric(sim_data$preemption) +
params$beta_BRT * sim_data$baseline_RT +
sim_data$b_i +
sim_data$u_j +
sim_data$v_j * sim_data$condition +
rnorm(n*5, 0, params$sd_resid)
sim_data <- sim_data %>% mutate(across(c(condition, stim_index, participant), as.factor))
sim_data$condition <- relevel(sim_data$condition, 2)
fit_sim<- lmer(
TCJ ~ condition + preemption + baseline_RT + (1 + condition | stim_index) + (1 | participant),
data = sim_data, REML = TRUE,
control = lmerControl(optimizer = "bobyqa")
)
fe <- fixef(fit_sim)
se <- sqrt(diag(vcov(fit_sim)))
delta_hat_est <- fe["condition1"]
delta_hat_se  <- se["condition1"]
# one-tailed: estimate > 0 with p < 0.05
t_val <- delta_hat_est / delta_hat_se
p_one_tailed <- 1 - pnorm(t_val)  # upper-tail
power_vec[i] <- as.numeric(t_val > qnorm(0.95))  # 1 if detected, 0 otherwise
emm_cond <- emmeans(fit_sim, ~ condition)
sig_vec[i] <- summary(contrast(
emm_cond_pure,
method = list("8/11" = c(-11, 8)),  # weights for (mu2, mu5)
adjust = "none"
))$p.value
}
