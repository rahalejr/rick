files <- list.files('data/pilot3/', pattern = "\\.csv$", full.names = TRUE)
n <- length(files)*5
df <- tibble(
participant_id = character(n),
participant    = numeric(n),
sim_index      = numeric(n),
TCJ            = numeric(n),
confidence     = numeric(n),
reselected     = logical(n),
condition      = character(n),
preemption     = logical(n),
baseline_RT    = numeric(n)
)
ind <- 1
pid <- 1
for (i in c(1:length(files))) {
dat <- tryCatch(
read.csv(files[i]),
error = function(e) {
message("Skipping file: ", files[i], " (", e$message, ")")
return(NULL)
}
)
if (is.null(dat) || ncol(dat) != 95) {
message("Skipping file: ", files[i], " (", ncol(dat), " cols)")
next
}
dat <- dat %>% filter(!if_any(c(select_resp.rt, stimuli_path), is.na))
participant_id <- dat$participant[1]
if (participant_id == '66465704f0921cfc20ba6e57') {
print(dat$baseline_rt)
}
baseline_rt <- median(dat$baseline_rt, na.rm=T)
print(baseline_rt)
for(j in c(4:8)) {
rt <- dat$select_resp.rt[j]
conf <- dat$conf_slider.response[j]
reselected <- dat$changed_selection[j]
stim_path <- strsplit(dat$stimuli_path[j], "/")[[1]]
num_balls <- stim_path[3]
preempted <- stim_path[4] == 'preemption'
sim_ind <- strsplit(stim_path[5], '\\.')[[1]][1]
sim_ind <- as.integer(substr(sim_ind, nchar(sim_ind), nchar(sim_ind)))
values <- list(
participant_id = participant_id,
participant    = pid,
sim_index      = sim_ind,
TCJ            = rt,
confidence     = conf,
reselected     = reselected,
condition      = num_balls,
preemption     = preempted,
baseline_RT    = baseline_rt
)
df[ind, ] <- values
ind <- ind + 1
}
pid <- pid + 1
}
df <- df %>%
filter(participant != 0) %>%
mutate(across(c(condition, sim_index, participant), as.factor))
df$condition <- relevel(factor(df$condition), "two_candidate")
df_clean <- df |>
group_by(condition) |>
mutate(
mean_rt = mean(TCJ, na.rm = TRUE),
sd_rt   = sd(TCJ, na.rm = TRUE),
keep    = (TCJ > mean_rt - 2 * sd_rt) & (TCJ < mean_rt + 2 * sd_rt)
) |>
filter(keep) |>
ungroup()
df_clean$BRTC <- scale(df_clean$baseline_RT, center = TRUE, scale = FALSE)
saveRDS(df_clean[,1:9], "data/cleaned/data.rds")
write.csv(df_clean[,1:9], 'data/cleaned/data.csv')
fit <- lmer(
TCJ ~ condition + preemption + baseline_RT + (1 + condition | sim_index) + (1 | participant),
data = df_clean, REML = TRUE,
control = lmerControl(optimizer = "bobyqa")
)
emm_cond <- emmeans(fit, ~ condition)
CSM_contrast <- contrast(
emm_cond_pure,
method = list("8/11" = c(-11, 8)),  # weights for (mu2, mu5)
adjust = "none"
)
CSM_contrast <- contrast(
emm_cond,
method = list("8/11" = c(-11, 8)),  # weights for (mu2, mu5)
adjust = "none"
)
CSM_contrast$p
