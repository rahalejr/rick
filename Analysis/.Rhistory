)
# pulling intercepts, coefficients, variances
vc <- VarCorr(fit)
sd_part <- attr(vc$participant, "stddev")[1]
sim_sdvec <- attr(vc$sim_index, "stddev")
# pulling intercepts, coefficients, variances
vc <- VarCorr(fit)
sd_part <- attr(vc$participant, "stddev")[1]
sim_sdvec <- attr(vc$sim_index, "stddev")
sd_item_intercept <- sim_sdvec[1]
sd_item_NC_slope  <- sim_sdvec[2]
cor_item_mat <- attr(vc$sim_index, "correlation")
cor_item <- cor_item_mat[1,2]
sd_resid <- sigma(fit)
fe <- fixef(fit)
beta0    <- unname(fe["(Intercept)"])
beta_PRE <- unname(fe["preemptionTRUE"])
beta_BRT <- unname(fe["baseline_RT"])
